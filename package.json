{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:a11y": "playwright test tests/e2e/a11y",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:chromatic": "chromatic --project-token=your-token",
    "test:mutation": "stryker run",
    "test:mutation:changed": "stryker run -m $(git diff --name-only origin/main | paste -sd ',' -)",
    "test:lighthouse": "node scripts/run-lighthouse.js",
    "test:load": "k6 run tests/load/k6-script.ts",
    "test:load:artillery": "artillery run tests/load/artillery.yml",
    "test:all": "npm run check && npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:ci": "npm run test:all && npm run test:coverage",
    "graphify": "tools\\mcp\\graphify\\.venv\\Scripts\\python.exe -m graphify ."
  },
